<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kantin Order</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="navbar">Kantin Order</div>

  <div class="container">
    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <div class="card">
      <h2>Menu Tersedia</h2>
      <% if (menus.length === 0) { %>
        <p>Belum ada menu yang tersedia saat ini.</p>
      <% } %>
      <% menus.forEach(menu => { %>
        <form class="inline-form" action="/orders" method="POST" style="margin-bottom: 14px; border-bottom: 1px solid #e5e7eb; padding-bottom: 14px;">
          <input type="hidden" name="menu_id" value="<%= menu.id %>">
          <div class="form-group">
            <label><%= menu.nama_menu %> &mdash; Rp <%= Number(menu.harga).toLocaleString('id-ID') %></label>
          </div>
          <div class="form-group">
            <label>Jumlah</label>
            <input type="number" name="qty" min="1" value="1" required style="width: 80px;">
          </div>
          <button type="submit">Pesan</button>
        </form>
      <% }) %>
    </div>

    <div class="card">
      <a href="/orders"><button type="button" class="secondary">Lihat Semua Pesanan</button></a>
    </div>
  </div>
</body>
</html>
